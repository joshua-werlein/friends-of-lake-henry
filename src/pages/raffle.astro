---
import type { D1Database, KVNamespace  } from "@cloudflare/workers-types";
import BaseLayout from "../layouts/BaseLayout.astro";
export const prerender = false;

const facebookPageLiveUrl = "https://www.facebook.com/61552199315213/videos/";

const rules = [
        "Daily drawings are held during the raffle month.",
    "All proceeds go to Lake Henry Project.",
    "If drawn, name goes in for remaining drawings.",
    'Every firearm has a minimum value of $1000; $800 cash option if you do not choose the firearm.',
    "All State & Federal laws apply; MUST be 21 or older to purchase a ticket.",
];

type LiveConfig = { latestVideoUrl: string | null; updatedAt: string | null };

type WinnerRow = {
    id: string;
    drawDate: string;
    ticketNumber: number;
    name: string;
    town: string;
    prize: string | null;
};

type Env = { DB?: D1Database; CONFIG?: KVNamespace };

const env = (Astro.locals as any).runtime?.env as Env | undefined;
const DB = env?.DB;

function isMonthKey(s: string) {
    return /^\d{4}-\d{2}$/.test(s);
}

const url = new URL(Astro.request.url);

// Optional month selector: /raffle?month=2025-11
const monthParam = (url.searchParams.get("month") ?? "").trim();

// Default to current month (America/Chicago)
const currentMonth = new Intl.DateTimeFormat("en-CA", {
    timeZone: "America/Chicago",
    year: "numeric",
    month: "2-digit",
}).format(new Date()).slice(0, 7); // YYYY-MM

let raffleKey = isMonthKey(monthParam) ? monthParam : currentMonth;

function monthKeyToLabel(monthKey: string) {
    const [y, m] = monthKey.split("-").map(Number);
    const d = new Date(Date.UTC(y, m - 1, 15, 12)); // 15th @ noon UTC = safe
    return new Intl.DateTimeFormat("en-US", {
        timeZone: "America/Chicago",
        month: "long",
        year: "numeric",
    }).format(d);
}

function shiftMonthKey(monthKey: string, delta: number) {
    const [y, m] = monthKey.split("-").map(Number);
    const d = new Date(Date.UTC(y, m - 1 + delta, 1, 12));
    return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
}

let months: string[] = [currentMonth];

if (DB) {
    const winnerMonthsRes = await DB.prepare(
        `SELECT DISTINCT raffle_key as monthKey
         FROM raffle_winners
         ORDER BY raffle_key DESC`
    ).all();

    const metaMonthsRes = await DB.prepare(
        `SELECT DISTINCT month_key as monthKey
         FROM raffle_months
         ORDER BY month_key DESC`
    ).all();

    months = Array.from(new Set([
        currentMonth,
        ...(winnerMonthsRes.results ?? []).map((r: any) => String(r.monthKey ?? "").trim()),
        ...(metaMonthsRes.results ?? []).map((r: any) => String(r.monthKey ?? "").trim()),
    ]))
        .filter(isMonthKey)
        .sort((a, b) => b.localeCompare(a));
}

if (!isMonthKey(raffleKey)) {
    raffleKey = currentMonth;
}

const prevMonthKey = shiftMonthKey(raffleKey, -1);
const nextMonthKey = shiftMonthKey(raffleKey, 1);
const monthLabel = monthKeyToLabel(raffleKey);

let winners: WinnerRow[] = [];

if (DB) {
    const { results } = await DB.prepare(
        `SELECT id,
            draw_date as drawDate,
            ticket_number as ticketNumber,
            winner_name as name,
            town,
            prize
     FROM raffle_winners
     WHERE raffle_key = ?
     ORDER BY draw_date DESC, created_at DESC`
    ).bind(raffleKey).all();
    winners = (results ?? []) as any;
}

let raffleTitle: string | null = null;

if (DB) {
    const metaRes = await DB.prepare(
        `SELECT title FROM raffle_months WHERE month_key = ?`
    ).bind(raffleKey).first();

    raffleTitle = metaRes ? String((metaRes as any).title ?? "").trim() : "";
    if (!raffleTitle) raffleTitle = null;
}

let heroPosterMonthKey: string | null = null;
let heroPosterKey: string | null = null;
let heroPosterAlt: string | null = null;

if (DB) {
    const upcomingPosterRes = await DB.prepare(
        `SELECT month_key, poster_key, poster_alt
         FROM raffle_months
         WHERE poster_key IS NOT NULL
           AND trim(poster_key) != ''
           AND month_key >= ?
         ORDER BY month_key ASC
         LIMIT 1`
    ).bind(currentMonth).first();

    const fallbackPosterRes = !upcomingPosterRes
        ? await DB.prepare(
            `SELECT month_key, poster_key, poster_alt
             FROM raffle_months
             WHERE poster_key IS NOT NULL
               AND trim(poster_key) != ''
             ORDER BY month_key DESC
             LIMIT 1`
        ).first()
        : null;

    const posterRes = upcomingPosterRes ?? fallbackPosterRes;

    heroPosterMonthKey = posterRes ? String((posterRes as any).month_key ?? "").trim() : "";
    heroPosterKey = posterRes ? String((posterRes as any).poster_key ?? "").trim() : "";
    heroPosterAlt = posterRes ? String((posterRes as any).poster_alt ?? "").trim() : "";

    if (!heroPosterMonthKey) heroPosterMonthKey = null;
    if (!heroPosterKey) heroPosterKey = null;
    if (!heroPosterAlt) heroPosterAlt = null;
}

let liveConfig: LiveConfig = { latestVideoUrl: null, updatedAt: null };

try {
    const raw = await env?.CONFIG?.get("raffle_live");

    if (raw) {
        const parsed = JSON.parse(raw) as Partial<LiveConfig>;
        const cur = typeof parsed.latestVideoUrl === "string" ? parsed.latestVideoUrl.trim() : "";

        liveConfig = {
            latestVideoUrl: cur.length ? cur : null,
            updatedAt: typeof parsed.updatedAt === "string" ? parsed.updatedAt : null,
        };
    }
} catch {
    // ignore bad KV / parse
}
const initial = {
    monthKey: raffleKey,
    prevMonthKey,
    nextMonthKey,
};

const effectiveVideoUrl = liveConfig.latestVideoUrl ?? null;

const isReel = effectiveVideoUrl ? /\/reel\/\d+/.test(effectiveVideoUrl) : false;

const embedSrc = effectiveVideoUrl
    ? isReel
        ? `https://www.facebook.com/plugins/post.php?href=${encodeURIComponent(effectiveVideoUrl)}&show_text=0&width=500`
        : `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(effectiveVideoUrl)}&show_text=0&adapt_container_width=true`
    : null;

const updatedAtDate = liveConfig.updatedAt ? new Date(liveConfig.updatedAt) : null;
const updatedAtLabel =
    updatedAtDate && Number.isFinite(updatedAtDate.getTime())
        ? updatedAtDate.toLocaleString("en-US", {
              timeZone: "America/Chicago",
              year: "numeric",
              month: "short",
              day: "numeric",
              hour: "numeric",
              minute: "2-digit",
          })
        : null;
const title = "Raffle | Friends of Lake Henry";
const description =
    "View current raffle information and winners supporting Friends of Lake Henry fundraising and lake restoration efforts.";
---

<BaseLayout title={title} description={description}>
    <div class="container  rafflePage">
        <section class="card hero enter-block">
            <div class="heroInfoColumn">
                <div class="heroLeft">
                    <div class="kicker">Friends of Lake Henry</div>
                    <h1>Raffle Winners & Live Drawings</h1>
                    <p class="lead">
                        Watch drawings on Facebook Live and see winners from past raffles.
                    </p>

                    <p class="fine">
                        Ticket sales and raffle details will be posted when available.
                    </p>
                </div>

                <div class="heroRight">
                    <div class="infoCard enter-block delay-3">
                        <div class="infoTitle">Friends of Lake Henry</div>
                        <div class="muted">P.O. Box 142, Blair, WI 54616</div>
                        <div class="muted">Phone: 608-484-9241</div>
                        <div class="muted" style="margin-top:.5rem;">
                            Winners are posted on Facebook.
                        </div>
                    </div>
                </div>
            </div>

            <button
                class="heroPoster"
                id="raffleHeroPoster"
                type="button"
                style={heroPosterKey ? "" : "display:none;"}
                aria-label="Open raffle poster preview"
            >
                <img
                    id="raffleHeroPosterImg"
                    src={heroPosterKey && heroPosterMonthKey ? `/api/raffle/poster?month=${encodeURIComponent(heroPosterMonthKey)}` : ""}
                    alt={heroPosterAlt ?? "Upcoming raffle poster"}
                    loading="lazy"
                />
            </button>
        </section>
        <dialog id="posterModal" class="posterModal">
            <button type="button" class="posterModalClose" id="posterModalClose" aria-label="Close poster preview">
                ×
            </button>
            <img
                id="posterModalImg"
                src=""
                alt=""
            />
        </dialog>
        <section class="card liveCard enter-block delay-3">
            <h2 class="sectionTitle">Latest Raffle</h2>

            <div class="panel livePanel enter-block delay-4">
                {embedSrc ? (
                    <div class="liveFrame">
                        <iframe
                            class="fbFrame"
                            src={embedSrc}
                            title="Friends of Lake Henry — Facebook Video"
                            loading="lazy"
                            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
                            allowfullscreen
                        ></iframe>
                    </div>
                ) : (
                    <div class="liveFrame liveFrame--empty">
                        <div class="liveOverlay">
                            <p class="muted" style="margin:0 0 .75rem;">
                                Live is offline right now. Watch on Facebook for the newest broadcast.
                            </p>
                            <a class="btn  btn--facebook" href={facebookPageLiveUrl} target="_blank" rel="noopener noreferrer">
                                Watch on Facebook
                            </a>
                        </div>
                    </div>
                )}

                {updatedAtLabel && (
                    <p class="muted" style="margin:.5rem 0 0;">Last updated: {updatedAtLabel}</p>
                )}

                {embedSrc && (
                    <div class="liveFallback enter-block delay-5">
                        <a class="btn  btn--facebook" href={facebookPageLiveUrl} target="_blank" rel="noopener noreferrer">
                            Watch on Facebook
                        </a>
                    </div>
                )}
            </div>
        </section>

        <section class="card winnersCard enter-block delay-6">
            <h2 class="sectionTitle">Past Winners</h2>
            <nav class="monthNav" aria-label="Select raffle month">
                <div class="monthMeta" aria-live="polite">
                    <div class="monthNavLabel" id="monthLabel">{monthLabel}</div>
                    {/* Reserve space even when empty (no layout jump) */}
                    <div class="monthTitle" id="raffleTitle">
                        {raffleTitle ?? ""}
                    </div>
                </div>
                <div class="monthControls">
                    <button class="pill" type="button" data-month-nav="prev" aria-label="Previous month">
                        ← Prev
                    </button>
                    <label class="srOnly" for="monthSelect">Select month</label>
                    <select id="monthSelect" class="monthSelect">
                        {months.map((m) => (
                                <option value={m} selected={m === raffleKey}>{monthKeyToLabel(m)}</option>
                        ))}
                    </select>
                    <button class="pill" type="button" data-month-nav="next" aria-label="Next month">
                        Next →
                    </button>
                </div>
            </nav>
            <div id="winnersPanel" class="panel winnersPanel enter-block delay-7">
                <div class="winnersTableWrap" role="region" aria-label="Raffle winners list">
                    <table class="winnersTable">
                        <colgroup>
                            <col class="colDate" />
                            <col class="colTicket" />
                            <col class="colName" />
                            <col class="colTown" />
                        </colgroup>

                        <thead>
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">Ticket</th>
                            <th scope="col">Name</th>
                            <th scope="col" class="thTown">Town</th>
                        </tr>
                        </thead>

                        <tbody id="winnersTbody">
                        {winners.map((w) => (
                            <tr>
                                <td class="tdDate">
                                    <time class="winDate" datetime={w.drawDate}>
                                        <span class="dateDesktop">
                                          {w.drawDate.slice(5,7)}/{w.drawDate.slice(8,10)}/{w.drawDate.slice(0,4)}
                                        </span>
                                                                        <span class="dateMobile">
                                          {w.drawDate.slice(5,7)}/{w.drawDate.slice(8,10)}
                                        </span>
                                    </time>
                                </td>
                                <td>{w.ticketNumber}</td>
                                <td class="tdName">{w.name}</td>
                                <td class="tdTown">{w.town}</td>
                            </tr>
                        ))}
                        </tbody>
                    </table>
                </div>

                <p class="muted" id="winnersEmpty" style={winners.length ? "display:none;margin:.75rem 0 0;" : "margin:.75rem 0 0;"}>
                    No winners posted for {monthLabel} yet.
                </p>
            </div>
        </section>

        <section class="card rules  enter-block delay-8">
            <h2>Rules</h2>
            <ul>
                {rules.map((r) => <li>{r}</li>)}
            </ul>
        </section>
    </div>
    <script
        id="raffleInitialState"
        type="application/json"
        set:html={JSON.stringify(initial)}
    ></script>
    <script type="module">
        const initialEl = document.getElementById("raffleInitialState");
        const initial = /** @type {{monthKey:string, prevMonthKey:string|null, nextMonthKey:string|null}} */ (
            JSON.parse((initialEl?.textContent || "{}").trim())
        );

        let state = { ...initial };

        const prevBtn = document.querySelector('button[data-month-nav="prev"]');
        const nextBtn = document.querySelector('button[data-month-nav="next"]');
        const monthLabelEl = document.getElementById("monthLabel");
        const raffleTitleEl = document.getElementById("raffleTitle");
        const monthSelect = document.getElementById("monthSelect");
        const heroPosterEl = document.getElementById("raffleHeroPoster");
        const heroPosterImgEl = document.getElementById("raffleHeroPosterImg");
        const posterModal = document.getElementById("posterModal");
        const posterModalImg = document.getElementById("posterModalImg");
        const posterModalClose = document.getElementById("posterModalClose");

        function bindPosterModal() {
            if (!(heroPosterEl instanceof HTMLButtonElement)) return;
            if (!(heroPosterImgEl instanceof HTMLImageElement)) return;
            if (!(posterModal instanceof HTMLDialogElement)) return;
            if (!(posterModalImg instanceof HTMLImageElement)) return;

            heroPosterEl.addEventListener("click", () => {
                const src = heroPosterImgEl.getAttribute("src") || "";
                const alt = heroPosterImgEl.getAttribute("alt") || "";

                if (!src) return;

                posterModalImg.src = src;
                posterModalImg.alt = alt;
                posterModal.showModal();
            });

            if (posterModalClose instanceof HTMLButtonElement) {
                posterModalClose.addEventListener("click", () => posterModal.close());
            }

            posterModal.addEventListener("click", (e) => {
                const rect = posterModal.getBoundingClientRect();
                const clickedInDialog =
                    rect.top <= e.clientY &&
                    e.clientY <= rect.top + rect.height &&
                    rect.left <= e.clientX &&
                    e.clientX <= rect.left + rect.width;

                if (!clickedInDialog) posterModal.close();
            });
        }

        function setNavDisabled(prevMonthKey, nextMonthKey) {
            if (prevBtn instanceof HTMLButtonElement) {
                prevBtn.disabled = !prevMonthKey;
                prevBtn.style.opacity = prevBtn.disabled ? ".5" : "";
                prevBtn.style.pointerEvents = prevBtn.disabled ? "none" : "";
                prevBtn.dataset.targetMonth = prevMonthKey || "";
            }
            if (nextBtn instanceof HTMLButtonElement) {
                nextBtn.disabled = !nextMonthKey;
                nextBtn.style.opacity = nextBtn.disabled ? ".5" : "";
                nextBtn.style.pointerEvents = nextBtn.disabled ? "none" : "";
                nextBtn.dataset.targetMonth = nextMonthKey || "";
            }
        }

        function renderPoster(posterUrl, posterAlt) {
                        if (!(heroPosterEl instanceof HTMLElement)) return;
                        if (!(heroPosterImgEl instanceof HTMLImageElement)) return;

                        if (!posterUrl) {
                            heroPosterEl.style.display = "none";
                            heroPosterImgEl.removeAttribute("src");
                            heroPosterImgEl.alt = "";
                            return;
                        }

                        heroPosterEl.style.display = "";
                        heroPosterImgEl.src = posterUrl;
                        heroPosterImgEl.alt = (posterAlt ?? "").trim() || "Raffle poster";
                    }

        function renderWinners(monthLabel, raffleTitle, winners) {

            if (monthLabelEl) monthLabelEl.textContent = monthLabel;

            if (raffleTitleEl instanceof HTMLElement) {
                const title = (raffleTitle ?? "").trim();
                raffleTitleEl.textContent = title;
                raffleTitleEl.classList.toggle("isEmpty", !title);
            }

            const tbody = document.getElementById("winnersTbody");
            const empty = document.getElementById("winnersEmpty");
            const wrap = document.querySelector(".winnersTableWrap");

            if (!(tbody instanceof HTMLTableSectionElement)) return;

            // clear rows
            tbody.replaceChildren();

            if (!Array.isArray(winners) || winners.length === 0) {
                if (wrap instanceof HTMLElement) wrap.hidden = true;
                if (empty instanceof HTMLElement) {
                    empty.textContent = `No winners posted for ${monthLabel} yet.`;
                    empty.style.display = "";
                }
                return;
            }

            if (wrap instanceof HTMLElement) wrap.hidden = false;
            if (empty instanceof HTMLElement) empty.style.display = "none";

            for (const w of winners) {
                const iso = String(w.drawDate ?? "");
                const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
                const yyyy = m ? m[1] : "";
                const mm = m ? m[2] : "";
                const dd = m ? m[3] : "";

                const tr = document.createElement("tr");

                // Date cell
                const tdDate = document.createElement("td");
                tdDate.className = "tdDate";

                const time = document.createElement("time");
                time.className = "winDate";
                time.setAttribute("datetime", iso);

                const spanDesktop = document.createElement("span");
                spanDesktop.className = "dateDesktop";
                spanDesktop.textContent = (mm && dd && yyyy) ? `${mm}/${dd}/${yyyy}` : "";

                const spanMobile = document.createElement("span");
                spanMobile.className = "dateMobile";
                spanMobile.textContent = (mm && dd) ? `${mm}/${dd}` : "";

                time.append(spanDesktop, spanMobile);
                tdDate.appendChild(time);

                // Ticket cell
                const tdTicket = document.createElement("td");
                tdTicket.textContent = String(w.ticketNumber ?? "");

                // Name cell
                const tdName = document.createElement("td");
                tdName.className = "tdName";
                tdName.textContent = String(w.name ?? "");

                // Town cell
                const tdTown = document.createElement("td");
                tdTown.className = "tdTown";
                tdTown.textContent = String(w.town ?? "");

                tr.append(tdDate, tdTicket, tdName, tdTown);
                tbody.appendChild(tr);
            }
            // when month changes, snap scroll back to left so Date is visible
            if (wrap) wrap.scrollLeft = 0;
        }

        async function loadMonth(targetMonthKey, pushUrl = true) {
            const u = new URL("/api/raffle/month", window.location.origin);
            u.searchParams.set("month", targetMonthKey);

            const res = await fetch(u.toString(), { headers: { "Accept": "application/json" } });
            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data?.ok) throw new Error(data?.error ?? "Failed to load month");

            // update state
            state = {
                monthKey: data.monthKey,
                prevMonthKey: data.prevMonthKey,
                nextMonthKey: data.nextMonthKey,
            };

            if (monthSelect instanceof HTMLSelectElement) { monthSelect.value = state.monthKey; }

            if (monthSelect instanceof HTMLSelectElement && Array.isArray(data.months)) {
                monthSelect.replaceChildren();
                for (const m of data.months) {
                    const opt = document.createElement("option");
                    opt.value = m.key;
                    opt.textContent = m.label ?? m.key;
                    monthSelect.appendChild(opt);
                }
                monthSelect.value = state.monthKey;
            }

            setNavDisabled(state.prevMonthKey, state.nextMonthKey);
            renderWinners(data.monthLabel, data.raffleTitle, data.winners);
            if (data.rafflePosterUrl) {
                renderPoster(data.rafflePosterUrl, data.rafflePosterAlt);
            }

            if (pushUrl) {
                const nextUrl = new URL(window.location.href);
                nextUrl.searchParams.set("month", state.monthKey);
                window.history.pushState({}, "", nextUrl.toString());
            }
        }

        function bindNav() {
            if (prevBtn instanceof HTMLButtonElement) {
                prevBtn.addEventListener("click", async () => {
                    const target = prevBtn.dataset.targetMonth;
                    if (!target) return;
                    await loadMonth(target);
                });
            }
            if (nextBtn instanceof HTMLButtonElement) {
                nextBtn.addEventListener("click", async () => {
                    const target = nextBtn.dataset.targetMonth;
                    if (!target) return;
                    await loadMonth(target);
                });
            }
        }

        function bindMonthSelect() {
            if (!(monthSelect instanceof HTMLSelectElement)) return;

            monthSelect.addEventListener("change", async () => {
                const target = monthSelect.value;
                if (!target) return;
                await loadMonth(target);
            });
        }

        window.addEventListener("popstate", () => {
            const u = new URL(window.location.href);
            const mk = (u.searchParams.get("month") ?? "").trim();
            if (/^\d{4}-\d{2}$/.test(mk)) loadMonth(mk, false);
        });

        // init: disable buttons based on SSR state, bind once
        setNavDisabled(state.prevMonthKey, state.nextMonthKey);
        bindNav();
        bindMonthSelect();

       (function initFbEmbedFailover() {
         const iframe = document.querySelector(".fbFrame");
         const fallback = document.querySelector(".liveFallback");

         if (!(iframe instanceof HTMLIFrameElement)) return;
         if (!(fallback instanceof HTMLElement)) return;

         const frame = iframe.closest(".liveFrame");
         if (!(frame instanceof HTMLElement)) return;

         let settled = false;

         const fail = () => {
           if (settled) return;
           settled = true;
           frame.style.display = "none";
           fallback.style.display = "flex";
         };

         const t = window.setTimeout(fail, 6500);
         bindPosterModal();

         iframe.addEventListener("load", () => {
           if (settled) return;
           settled = true;
           window.clearTimeout(t);
         });

         iframe.addEventListener("error", () => {
           window.clearTimeout(t);
           fail();
         });
       })();
    </script>
    <style>
        .hero {
            margin-top: var(--section-gap);
            padding: 2rem;
            display: grid;
            grid-template-columns: minmax(320px, 1fr) minmax(320px, 520px);
            gap: 1.25rem;
            align-items: stretch;
        }

        .heroInfoColumn {
            display: grid;
            grid-template-rows: 1fr 1fr;
            gap: 1.25rem;
            min-width: 0;
            height: 100%;
        }

        .heroLeft,
        .heroRight {
            min-width: 0;
            height: 100%;
        }

        .heroLeft {
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1.25rem;
            background: rgba(0,0,0,0.22);
            backdrop-filter: blur(2px);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .heroPoster {
            display: block;
            align-self: stretch;
            min-width: 0;
            width: 100%;
            height: 100%;
            max-width: 520px;
            margin: 0 auto;
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid var(--border-strong);
            background: rgba(0,0,0,0.16);
            padding: 0;
            cursor: zoom-in;
        }

        .heroPoster img {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            background: rgba(0,0,0,0.08);
        }

        .heroRight .infoCard {
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .posterModal {
            border: 0;
            padding: 0;
            background: transparent;
            max-width: min(92vw, 1200px);
        }

        .posterModal::backdrop {
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(4px);
        }

        .posterModal img {
            display: block;
            max-width: 100%;
            max-height: 88vh;
            width: auto;
            height: auto;
            border-radius: 16px;
            border: 1px solid var(--border-strong);
            background: #111;
        }

        .posterModalClose {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            z-index: 2;
            border: 0;
            border-radius: 999px;
            width: 2.25rem;
            height: 2.25rem;
            font-size: 1.5rem;
            cursor: pointer;
            background: rgba(0,0,0,0.7);
            color: white;
        }

        .kicker { color: var(--muted); font-weight: 800; letter-spacing: .3px; }
        .lead { margin: 0; max-width: 70ch; }

        .fine { margin: .75rem 0 0; color: var(--muted); font-size: .95rem; }

        .infoCard {
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1.25rem;
            background: rgba(0,0,0,0.28);
            backdrop-filter: blur(2px);
        }
        .infoTitle { font-weight: 900; margin-bottom: .25rem; }
        .muted { color: var(--muted); }

        .sectionTitle { margin: 0 0 1rem; font-size: 1.35rem; }

        .blank {
            background: transparent;
            border: 1px dashed rgba(255,255,255,0.08);
        }

        .rules {
            margin-top: var(--section-gap);
            margin-bottom: calc(var(--section-gap) * 1.25);
            padding: 1.5rem 1.75rem;
            border-radius: 14px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
        }
        .rules ul { margin: 0; padding-left: 1.1rem; color: var(--muted); }
        .rules li { margin: 0.4rem 0;
            line-height: 1.5; }
        .liveCard{
            margin-top: var(--section-gap);
            padding: 1.5rem;
        }

        .livePanel{
            display: grid;
            gap: 1rem;
        }

        .liveFrame{
            aspect-ratio: 16 / 9;
            width: 100%;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.20);
        }

        .fbFrame{
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
        }

        .liveFallback{
            display: flex;
            gap: .75rem;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .liveFrame--empty{
            display:flex;
            align-items:center;
            justify-content:center;
            padding: 1.25rem;
        }

        .liveOverlay{
            text-align:center;
            max-width: 60ch;
        }

        /* make the Facebook CTA feel intentional without changing global .btn */
        .fbBtn{
            border-color: rgba(24,119,242,0.35);
        }
        .fbBtn:hover,
        .fbBtn:focus-visible{
            border-color: rgba(24,119,242,0.55);
        }

        .winnersCard{
            margin-top: var(--section-gap);
            padding: 1.5rem;
        }

        .monthNav{
            display: grid;
            gap: .6rem;
            margin: 0 auto 1rem;
            width: 100%;
            max-width: 980px;
        }

        .monthMeta { text-align: center; }
        .monthNavLabel{
            font-weight: 900;
            font-size: clamp(1.55rem, 1.7vw + 0.96rem, 2rem);
            line-height: 1.1;
        }

        /* Reserve space for title even if empty */
        .monthTitle{
            min-height: 1.25em;
            margin-top: .3rem;
            font-size: 1rem;
            color: var(--text-soft);
            opacity: 0.95;
        }
        /* If empty, keep space but visually hide */
        .monthTitle.isEmpty { opacity: 0; }

        /* Controls row: Prev | Select | Next */
        .monthControls{
            display: grid;
            grid-template-columns: auto auto auto;
            align-items: center;
            justify-content: center;
            gap: .75rem;
        }

        .monthSelect{
            width: auto;
            max-width: 14.5rem;
            min-width: 10rem;
            padding: .5rem 1rem;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--glass-dark);
            color: var(--text-bright);
            font-weight: 700;
            line-height: 1;
        }

        #raffleTitle{
            margin-top: .1rem;
            font-size: 1rem;
            color: var(--text-soft);
        }

        .dateMobile { display: none; }
        .dateDesktop { display: inline; }
        #winnersEmpty{ width: min(980px, 100%); text-align: center; }

        @media (max-width: 1100px) {
          .hero {
            grid-template-columns: 1fr;
          }

          .heroPoster {
            max-width: 720px;
          }
        }

        @media (max-width: 980px) {
            .hero {
                grid-template-columns: 1fr;
            }

            .heroInfoColumn {
                grid-template-rows: auto auto;
            }

            .heroPoster {
                max-width: 720px;
                height: auto;
            }

            .heroPoster img {
                height: auto;
            }
        }

        @media (min-width: 760px) and (max-width: 979px) {
            .hero { grid-template-columns: 1fr; }
            .winnersRow { column-gap: .75rem; }
        }
        /* Hide select below ~720px */
        @media (max-width: 720px){
            .monthControls{
                grid-template-columns: 1fr 1fr;  /* just Prev / Next */
                gap: .6rem;
            }
            .monthSelect{ display: none; }

            /* keep buttons full size */
            .monthControls > button{
                width: 100%;
                justify-content: center;
            }
        }
        @media (max-width: 520px) {
            .liveCard { padding: 1.1rem; }
            .liveFrame { border-radius: 12px; }
            .liveFallback{
                flex-direction: column;
                align-items: stretch;
            }
            .liveFallback .btn{
                width: 100%;
                justify-content: center;
            }
            .monthNav{gap:.5rem;}
            .monthNavCenter{min-width: 9rem;}
            .dateDesktop { display: none; }
            .dateMobile { display: inline; }
            .winnersPanel { padding: .85rem; }
            .winnersTable{ min-width: 520px; width: max-content;  table-layout: fixed;}

            .winnersTable th,
            .winnersTable td{
                padding: .5rem .45rem;
                font-size: .93rem;
            }
            .winnersTable col.colDate   { width: 5rem; }
            .winnersTable col.colTicket { width: 4rem; }
            .winnersTable col.colName   { width: 10.5rem; }
            .winnersTable col.colTown   { width: 8.5rem; }
            /* remove “dead space” at edges */
            .winnersTable th:first-child,
            .winnersTable td:first-child { padding-left: .35rem; }

            .winnersTable th:last-child,
            .winnersTable td:last-child  { padding-right: .25rem; }
        }
    </style>
    <style is:global>
        .rafflePage .winnersPanel{
            padding: 1rem;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.28);
            backdrop-filter: blur(2px);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .rafflePage .winnersTableWrap{
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(0,0,0,0.18);
            width: min(980px, 100%);
            padding: 0 1.25rem;
            display: flex;
            justify-content: center;
        }

        .rafflePage .winnersTable{
            width: max-content;
            min-width: 720px;
            border-collapse: collapse;
            table-layout: fixed;
            margin: 0;
        }

        .rafflePage .winnersTable col.colDate   { width: 8.5rem; }
        .rafflePage .winnersTable col.colTicket { width: 5.5rem; }
        .rafflePage .winnersTable col.colName   { width: 12rem; }
        .rafflePage .winnersTable col.colTown   { width: 12rem; }

        .rafflePage .winnersTable th,
        .rafflePage .winnersTable td{
            padding: .75rem .9rem;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            font-size: .98rem;
            vertical-align: middle;
            white-space: nowrap;
        }
        .rafflePage .winnersTable th:first-child,
        .rafflePage .winnersTable td:first-child {
            padding-left: 0;
        }
        .rafflePage .tdName,
        .rafflePage .tdTown{
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Date format toggle must be global because spans are injected */
        .rafflePage .dateMobile{ display:none; }
        .rafflePage .dateDesktop{ display:inline; }

        @media (min-width: 721px){
            .rafflePage .winnersTable{
                transform: translateX(0.75rem);
            }
        }

        @media (max-width:520px){
            .rafflePage .winnersTableWrap {
                justify-content: flex-start;
                padding-left: .75rem;
                padding-right: .5rem;
            }

            .rafflePage .winnersTable th,
            .rafflePage .winnersTable td {
                padding: .5rem .45rem;
                font-size: .93rem;
            }


            .rafflePage .winnersTable th:first-child,
            .rafflePage .winnersTable td:first-child {
                padding-left: 0;
            }
            .rafflePage .dateDesktop{ display:none; }
            .rafflePage .dateMobile{ display:inline; }
        }
    </style>
</BaseLayout>

